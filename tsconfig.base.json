{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["esnext", "dom"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"declaration": true,
		"declarationMap": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"erasableSyntaxOnly": true,
		"isolatedDeclarations": true,
	}
}
